{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/polaralias/okf-tasks/v0.3.0/schemas/task.schema.json",
  "title": "OKF Tasks v0.3 Task frontmatter",
  "type": "object",
  "required": ["type", "task", "title", "description", "status", "created", "timestamp"],
  "properties": {
    "type": { "const": "Task" },
    "task": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["proposed", "ready", "in-progress", "blocked", "validation", "done", "superseded", "deferred"]
    },
    "created": { "type": "string", "format": "date-time" },
    "timestamp": { "type": "string", "format": "date-time" },
    "started": { "type": "string", "format": "date-time" },
    "finished": { "type": "string", "format": "date-time" },
    "effort_minutes": { "type": "integer", "minimum": 0 },
    "estimate": {
      "type": "object",
      "required": ["effort_minutes", "method", "confidence", "basis", "actor", "timestamp"],
      "properties": {
        "effort_minutes": { "type": "integer", "minimum": 0 },
        "method": { "enum": ["agent", "manual", "historical"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "basis": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "sprint_points": {
      "type": "object",
      "required": ["value", "scale", "timestamp"],
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "scale": { "type": "string", "minLength": 1 },
        "context": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "completion_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finished", "reopened"],
        "properties": {
          "finished": { "type": "string", "format": "date-time" },
          "reopened": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "origin": { "type": "object", "additionalProperties": true },
    "owner": { "type": "string" },
    "assignees": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "priority": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "parent": { "type": "string", "minLength": 1 },
    "depends_on": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "external": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system", "id", "url"],
        "properties": {
          "system": { "type": "string", "minLength": 1 },
          "id": { "type": ["string", "integer"] },
          "url": { "type": "string", "format": "uri" },
          "status": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "sync": {
      "type": "object",
      "required": ["authority"],
      "properties": {
        "authority": { "enum": ["repository", "tracker", "manual"] },
        "last_synced": { "type": "string", "format": "date-time" },
        "revision": { "type": ["string", "integer"] },
        "field_authority": {
          "type": "object",
          "additionalProperties": { "enum": ["repository", "tracker", "manual"] }
        },
        "base": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
