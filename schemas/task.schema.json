{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/polaralias/okf-tasks/v0.5.0/schemas/task.schema.json",
  "title": "OKF Tasks v0.5 Task frontmatter",
  "type": "object",
  "required": ["type", "task", "title", "description", "status", "created", "timestamp"],
  "properties": {
    "type": { "const": "Task" },
    "task": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["proposed", "ready", "in-progress", "blocked", "validation", "done", "superseded", "deferred"]
    },
    "created": { "type": "string", "format": "date-time" },
    "timestamp": { "type": "string", "format": "date-time" },
    "started": { "type": "string", "format": "date-time" },
    "finished": { "type": "string", "format": "date-time" },
    "effort_minutes": { "type": "integer", "minimum": 0 },
    "time": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeEntry" }
    },
    "estimate": {
      "type": "object",
      "required": ["effort_minutes", "method", "confidence", "basis", "actor", "timestamp"],
      "properties": {
        "effort_minutes": { "type": "integer", "minimum": 0 },
        "method": { "enum": ["agent", "manual", "historical"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "basis": { "type": "string", "minLength": 1 },
        "actor": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "sprint_points": {
      "type": "object",
      "required": ["value", "scale", "timestamp"],
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "scale": { "type": "string", "minLength": 1 },
        "context": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "completion_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finished", "reopened"],
        "properties": {
          "finished": { "type": "string", "format": "date-time" },
          "reopened": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "origin": { "type": "object", "additionalProperties": true },
    "owner": { "type": "string" },
    "assignees": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "priority": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": { "enum": ["text", "number", "date", "boolean", "single-select", "multi-select", "user", "url"] },
          "value": {}
        },
        "additionalProperties": true
      }
    },
    "parent": { "type": "string", "minLength": 1 },
    "depends_on": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "external": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tracker", "system", "host", "kind", "scope", "id", "key", "url", "sync"],
        "properties": {
          "tracker": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "system": { "enum": ["github", "gitlab", "linear", "clickup"] },
          "host": { "type": "string", "format": "uri" },
          "kind": { "type": "string", "minLength": 1 },
          "scope": {
            "type": "object", "required": ["id", "key"],
            "properties": { "id": { "type": ["string", "integer"] }, "key": { "type": "string", "minLength": 1 } },
            "additionalProperties": true
          },
          "id": { "type": ["string", "integer"] },
          "key": { "type": ["string", "integer"] },
          "url": { "type": "string", "format": "uri" },
          "sync": {
            "type": "object",
            "properties": {
              "last_synced": { "type": "string", "format": "date-time" },
              "remote_revision": { "type": ["string", "integer"] },
              "base": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "timeEntry": {
      "type": "object",
      "required": ["id", "status", "actor", "started", "method", "activity"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "status": { "enum": ["running", "closed"] },
        "actor": { "type": "string", "minLength": 1 },
        "workstream": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "started": { "type": "string", "format": "date-time" },
        "finished": { "type": "string", "format": "date-time" },
        "elapsed_minutes": { "type": "integer", "minimum": 0 },
        "effort_minutes": { "type": "integer", "minimum": 0 },
        "method": { "enum": ["tracked", "tracked-adjusted", "manual", "estimated-commit-review"] },
        "summary": { "type": "string" },
        "basis": { "type": "string" },
        "activity": { "enum": ["implementation", "review", "validation", "knowledge-maintenance", "research", "planning", "coordination", "other"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "source_commits": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "estimation": {
          "type": "object",
          "properties": {
            "session_gap_minutes": { "type": "integer", "minimum": 1 },
            "allowance_minutes": { "type": "integer", "minimum": 0 },
            "session_count": { "type": "integer", "minimum": 1 },
            "sessions": { "type": "array", "minItems": 1 }
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "closed" } } },
          "then": { "required": ["finished", "effort_minutes"] }
        },
        {
          "if": { "properties": { "method": { "const": "estimated-commit-review" } } },
          "then": { "required": ["confidence", "source_commits", "estimation", "basis"] }
        },
        {
          "if": { "properties": { "method": { "enum": ["tracked-adjusted", "manual"] } } },
          "then": { "required": ["basis"] }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
